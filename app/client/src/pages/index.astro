---
import Layout from '../layouts/Layout.astro';
import DogList from '../components/DogList.astro';

const API_SERVER_URL = process.env.API_SERVER_URL || 'http://localhost:5100';
const PAGE_SIZE = 6;

let dogs = [];
let page = 1;
let totalPages = 1;
let breeds: string[] = [];
let error: string | null = null;

const currentPage = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const currentBreed = Astro.url.searchParams.get('breed') || '';
const availableOnly = Astro.url.searchParams.get('available') === 'true';

try {
  const breedsResponse = await fetch(`${API_SERVER_URL}/api/breeds`);
  if (breedsResponse.ok) {
    const breedsData = await breedsResponse.json();
    breeds = breedsData.breeds;
  }
} catch (err) {
  // Non-critical: filters will still render but breed dropdown will be empty
}

try {
  let apiUrl = `${API_SERVER_URL}/api/dogs?page=${currentPage}&per_page=${PAGE_SIZE}`;
  if (currentBreed) apiUrl += `&breed=${encodeURIComponent(currentBreed)}`;
  if (availableOnly) apiUrl += `&available=true`;

  const response = await fetch(apiUrl);
  if (response.ok) {
    const data = await response.json();
    dogs = data.dogs;
    page = data.page;
    totalPages = data.total_pages;
  } else {
    error = `Failed to fetch data: ${response.status} ${response.statusText}`;
  }
} catch (err) {
  error = `Error: ${err instanceof Error ? err.message : String(err)}`;
}

const paginationBase = `/?breed=${encodeURIComponent(currentBreed)}&available=${availableOnly}`;
---

<Layout title="Williams-Playground - Find Your Forever Friend">
  <div class="py-8">
    <div class="max-w-3xl mb-10">
      <h1 class="text-4xl font-bold mb-4 text-slate-100">Welcome to Williams-Playground</h1>
      <p class="text-xl text-slate-300">Find your perfect companion from our wonderful selection of dogs looking for their forever homes.</p>
    </div>

    {error ? (
      <div class="text-center py-12 bg-slate-800/50 backdrop-blur-sm rounded-xl border border-slate-700" data-testid="error-message">
        <p class="text-red-400">{error}</p>
      </div>
    ) : (
      <>
        <div class="flex flex-wrap items-center gap-4 mb-6" data-testid="filters">
          <select
            id="breed-filter"
            data-testid="breed-filter"
            class="bg-slate-800 border border-slate-700 text-slate-300 rounded-lg px-3 py-2 hover:border-blue-500/50 focus:outline-none focus:border-blue-500/50 transition-colors"
          >
            <option value="">All breeds</option>
            {breeds.map((breed) => (
              <option value={breed} selected={breed === currentBreed}>{breed}</option>
            ))}
          </select>

          <label class="flex items-center gap-2 text-slate-300 cursor-pointer" data-testid="available-filter-label">
            <input
              type="checkbox"
              id="available-filter"
              data-testid="available-filter"
              checked={availableOnly}
              class="w-4 h-4 accent-blue-500 cursor-pointer"
            />
            <span>Available for adoption only</span>
          </label>
        </div>

        <DogList dogs={dogs} />

        {totalPages > 1 && (
          <nav class="flex justify-center items-center gap-2 mt-10" data-testid="pagination">
            {page > 1 ? (
              <a
                href={`${paginationBase}&page=${page - 1}`}
                class="px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-300 hover:border-blue-500/50 hover:text-blue-400 transition-colors"
                data-testid="pagination-prev"
              >
                ← Previous
              </a>
            ) : (
              <span class="px-4 py-2 rounded-lg bg-slate-800/50 border border-slate-700/50 text-slate-600 cursor-not-allowed">
                ← Previous
              </span>
            )}

            <span class="px-4 py-2 text-slate-300" data-testid="pagination-info">
              Page {page} of {totalPages}
            </span>

            {page < totalPages ? (
              <a
                href={`${paginationBase}&page=${page + 1}`}
                class="px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-300 hover:border-blue-500/50 hover:text-blue-400 transition-colors"
                data-testid="pagination-next"
              >
                Next →
              </a>
            ) : (
              <span class="px-4 py-2 rounded-lg bg-slate-800/50 border border-slate-700/50 text-slate-600 cursor-not-allowed">
                Next →
              </span>
            )}
          </nav>
        )}
      </>
    )}
  </div>
</Layout>

<script>
  const breedFilter = document.getElementById('breed-filter') as HTMLSelectElement;
  const availableFilter = document.getElementById('available-filter') as HTMLInputElement;

  function applyFilters() {
    const params = new URLSearchParams();
    params.set('page', '1');

    const breed = breedFilter.value;
    if (breed) params.set('breed', breed);

    if (availableFilter.checked) params.set('available', 'true');

    window.location.href = `/?${params.toString()}`;
  }

  breedFilter.addEventListener('change', applyFilters);
  availableFilter.addEventListener('change', applyFilters);
</script>
